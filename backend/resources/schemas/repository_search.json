{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "repository_search",
  "description": "repository_search",
  "type": "object",
  "properties": {
    "page": {"type":  "integer", "minimum": 0},
    "perPage": {"type":  "integer", "minimum": 1},
    "search": {
      "type": "object",
      "properties": {
        "name": {
          "oneOf": [
            { "type": "string", "pattern": "^[^\\s]{3,}$" },
            { "type": "null" }
          ]
        },
        "description": {
          "oneOf": [
            { "type": "string", "pattern": "^[^\\s]{3,}$" },
            { "type": "null" }
          ]
        },
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "minVersion": {
                "oneOf": [
                  { "type": "string", "pattern": "^\\d{1,4}\\.\\d{1,4}\\.\\d{1,4}$" },
                  { "type": "null" }
                ]
              },
              "maxVersion": {
                "oneOf": [
                  { "type": "string", "pattern": "^\\d{1,4}\\.\\d{1,4}\\.\\d{1,4}$" },
                  { "type": "null" }
                ]
              }
            },
            "required": ["id", "minVersion", "maxVersion"]
          },
          "maxItems": 4
        }
      },
      "required": ["name", "description", "packages"]
    }
  },
  "required": ["page", "search"],
  "additionalProperties": false
}
